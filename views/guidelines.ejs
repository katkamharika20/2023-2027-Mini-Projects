<div class="page-header">
  <h1><i class="fas fa-book"></i> Safety Guidelines</h1>

  <% if (user.role !== 'user') { %>
    <button class="btn btn-primary" onclick="openGuidelineModal()">
      <i class="fas fa-plus"></i> Add Guideline
    </button>
  <% } %>
</div>

<div class="guidelines-grid">

  <% if (guidelines.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-book-open"></i>
      <p>No guidelines published yet</p>
    </div>
  <% } %>

  <% guidelines.forEach(g => { %>

    <div class="guideline-card">

      <div class="guideline-header">
        <span class="category-badge <%= g.category %>">
          <%= g.category.toUpperCase() %>
        </span>

        <span class="guideline-date">
          <%= new Date(g.updatedAt).toLocaleDateString() %>
        </span>
      </div>

      <h3><%= g.title %></h3>
      <p><%= g.content %></p>

      <div class="guideline-footer">
        <span>
          <i class="fas fa-user-shield"></i>
          <%= g.author ? g.author.username : 'Admin' %>
        </span>
      </div>

    </div>

  <% }) %>

</div>


<!-- Guideline Modal -->
<div id="guidelineModal" class="modal hidden">
  <div class="modal-content">

    <h3><i class="fas fa-plus"></i> New Guideline</h3>

    <div class="form-group">
      <label>Title</label>
      <input id="gTitle" maxlength="200" />
    </div>

    <div class="form-group">
      <label>Category</label>
      <select id="gCategory">
        <option value="general">General</option>
        <option value="emergency">Emergency</option>
        <option value="prevention">Prevention</option>
        <option value="reporting">Reporting</option>
      </select>
    </div>

    <div class="form-group">
      <label>Content</label>
      <textarea id="gContent" maxlength="5000" rows="5"></textarea>
    </div>

    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeGuidelineModal()">Cancel</button>
      <button class="btn btn-primary" onclick="submitGuideline()">Publish</button>
    </div>

  </div>
</div>
<h2>🚨 Emergency Contacts</h2>
<p>In case of an emergency, please contact the appropriate authorities immediately:</p>
<div class="guideline-card">
  <p><b>Police:</b> 100</p>
  <p><b>Ambulance:</b> 108</p>
  <p><b>Fire:</b> 101</p>
</div>